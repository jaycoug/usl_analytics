WgtFreq_UCL = round(hbi_totals_ci[, 2]),
Percent = round(as.vector(t(health_by_inc[, 2:3])) * 100, 4),
StdErr_Percent = round(as.vector(t(health_by_inc_se)) * 100, 4),
LowerCL = round(health_by_inc_ci[, 1] * 100, 4),
UpperCL = round(health_by_inc_ci[, 2] * 100, 4)
)
print(income_results, row.names = FALSE)
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(survey)
# Data Prep
ky24_rf <- KY24[, c("_RFHLTH", "_SEX", "INCOME3", "_RACE", "EDUCA",
"_STSTR", "_PSU", "_LLCPWT")]
ky24_rf_clean <- ky24_rf %>%
filter(`_RFHLTH` %in% c(1, 2)) %>%
mutate(
Sex = factor(`_SEX`, levels = c(1, 2), labels = c("Male", "Female")),
Health = factor(`_RFHLTH`, levels = c(1, 2), labels = c("Good/Better", "Fair/Poor")),
Race_labeled = factor(`_RACE`, levels = c(1, 2, 6, 7, 8), labels = c("White/Non-Hisp", "Black or Afr. Am./Non-Hisp", "Oth. Race/Non-Hisp", "MultiRacial/Non-Hisp", "Hispanic")),
Education_labeled = factor(
case_when(
EDUCA %in% c(1, 2, 3) ~ "Less Than H.S.",
EDUCA == 4 ~ "H.S. or G.E.D",
EDUCA == 5 ~ "Some Post-H.S.",
EDUCA == 6 ~ "College Graduate",
TRUE ~ NA_character_
), levels = c("Less Than H.S.","H.S. or G.E.D","Some Post-H.S.","College Graduate")
),
Income_labeled = factor(
case_when(
INCOME3 %in% c(1, 2) ~ "Less than $15,000",
INCOME3 %in% c(3, 4) ~ "$15,000-24,999",
INCOME3 == 5 ~ "$25,000-34,999",
INCOME3 == 6 ~ "$35,000-49,999",
INCOME3 %in% c(7, 8) ~ "$50,000-99,999",
INCOME3 %in% c(9, 10) ~ "$100,000-199,999",
TRUE ~ NA_character_
), levels = c("Less than $15,000", "$15,000-24,999", "$25,000-34,999",
"$35,000-49,999", "$50,000-99,999", "$100,000-199,999")
)
)
# Survey Designs
design_full <- svydesign(
id = ~`_PSU`,
strata = ~`_STSTR`,
weights = ~`_LLCPWT`,
data = ky24_rf_clean,
nest = TRUE
)
design_race_sub <- subset(design_full, !is.na(Race_labeled))
design_educ_sub <- subset(design_full, !is.na(Education_labeled))
design_income_sub <- subset(design_full, !is.na(Income_labeled))
# Helper function for overall health status table (no grouping variable)
health_table_overall <- function(design, data, table_title) {
cat("\n===============================================================\n")
cat(table_title, "\n")
cat("===============================================================\n\n")
# Survey statistics
health_mean <- svymean(~Health, design = design, na.rm = TRUE)
health_mean_ci <- confint(health_mean)
health_mean_se <- SE(health_mean)
health_total <- svytotal(~Health, design = design, na.rm = TRUE)
health_total_ci <- confint(health_total, df = degf(design))
health_total_se <- SE(health_total)
# Unweighted counts
health_counts <- table(data$Health)
# Build results table
results <- data.frame(
Health_Status = names(health_counts),
Frequency = as.vector(health_counts),
Weighted_Freq = round(as.vector(health_total)),
StdErr_WgtFreq = round(as.vector(health_total_se)),
WgtFreq_LCL = round(health_total_ci[, 1]),
WgtFreq_UCL = round(health_total_ci[, 2]),
Percent = round(as.vector(health_mean) * 100, 4),
StdErr_Percent = round(as.vector(health_mean_se) * 100, 4),
LowerCL = round(health_mean_ci[, 1] * 100, 4),
UpperCL = round(health_mean_ci[, 2] * 100, 4)
)
# Add total row
total_row <- data.frame(
Health_Status = "Total",
Frequency = sum(health_counts),
Weighted_Freq = round(sum(weights(design))),
StdErr_WgtFreq = NA,
WgtFreq_LCL = NA,
WgtFreq_UCL = NA,
Percent = 100,
StdErr_Percent = NA,
LowerCL = NA,
UpperCL = NA
)
results <- rbind(results, total_row)
print(results, row.names = FALSE)
invisible(results)
}
# Helper function for health status tables by demographic
health_table_by <- function(design, group_var, data, table_title) {
cat("\n===============================================================\n")
cat(table_title, "\n")
cat("===============================================================\n\n")
# Build formula for grouping variable
group_formula <- as.formula(paste0("~", group_var))
# Survey statistics
health_mean <- svyby(~Health, group_formula, design = design, svymean, na.rm = TRUE)
health_mean_ci <- confint(health_mean)
health_mean_se <- SE(health_mean)
health_total <- svyby(~Health, group_formula, design = design, svytotal, na.rm = TRUE)
health_total_ci <- confint(health_total)
health_total_se <- SE(health_total)
# Unweighted counts
counts <- data %>%
filter(!is.na(.data[[group_var]])) %>%
group_by(.data[[group_var]], Health) %>%
summarise(N = n(), .groups = "drop") %>%
pivot_wider(names_from = Health, values_from = N, values_fill = 0)
n_cats <- nrow(counts)
# Build results table
results <- data.frame(
Group = rep(counts[[group_var]], each = 2),
Health_Status = rep(c("Good/Better", "Fair/Poor"), n_cats),
Frequency = as.vector(rbind(counts$`Good/Better`, counts$`Fair/Poor`)),
Weighted_Freq = round(as.vector(t(health_total[, 2:3]))),
StdErr_WgtFreq = round(as.vector(t(health_total_se))),
WgtFreq_LCL = round(health_total_ci[, 1]),
WgtFreq_UCL = round(health_total_ci[, 2]),
Percent = round(as.vector(t(health_mean[, 2:3])) * 100, 4),
StdErr_Percent = round(as.vector(t(health_mean_se)) * 100, 4),
LowerCL = round(health_mean_ci[, 1] * 100, 4),
UpperCL = round(health_mean_ci[, 2] * 100, 4)
)
names(results)[1] <- group_var
print(results, row.names = FALSE)
invisible(results)
}
health_table_overall(design_full, ky24_rf_clean,
"TABLE 1: OVERALL HEALTH STATUS DISTRIBUTION")
health_table_by(design_full, "Sex", ky24_rf_clean,
"TABLE 2: HEALTH STATUS BY SEX")
health_table_by(design_race_sub, "Race_labeled", ky24_rf_clean,
"TABLE 3: HEALTH STATUS BY RACE/ETHNICITY")
health_table_by(design_educ_sub, "Education_labeled", ky24_rf_clean,
"TABLE 4: HEALTH STATUS BY EDUCATION")
health_table_by(design_income_sub, "Income_labeled", ky24_rf_clean,
"TABLE 5: HEALTH STATUS BY INCOME")
